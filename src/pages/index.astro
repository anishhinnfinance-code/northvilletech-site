---
import BaseLayout from '../layouts/BaseLayout.astro';
import Newsletter from '../components/Newsletter.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const recent = posts.slice(0, 5);

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout
  title="Northville Tech — Guides for DoorDash Drivers & Gig Workers"
  description="Practical guides for DoorDash drivers and gig workers. Mileage tracking, tax tips, earnings strategies, and honest reviews — no fluff."
>
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <h1>Built for the gig life.</h1>
        <p class="lede">
          Real guides for DoorDash drivers and gig workers — from tracking mileage for taxes to
          maximizing your earnings. No fluff, no generic advice, no "ultimate guides" that weren't.
        </p>
        <div class="hero-ctas">
          <a href="http://northvilletech.co/dasher" class="btn btn-primary" rel="sponsored nofollow">Start Dashing →</a>
          <a href="#recent" class="btn btn-outline" style="color:#fff;border-color:#fff;">Read the guides ↓</a>
        </div>
      </div>
    </div>
  </section>

  <section class="container" style="margin-top: 3rem;">
    <div class="section-heading">
      <h2>Start here</h2>
    </div>
    <div class="card-grid">
      <a class="card" href="/blog/how-to-track-doordash-mileage-for-taxes">
        <span class="card-tag">Tax Guide</span>
        <h3>How to Track Your DoorDash Mileage for Taxes</h3>
        <p>The IRS lets you deduct 67 cents per mile — but only if you tracked them. Here's the exact method that saves DoorDash drivers the most money at tax time.</p>
      </a>
      <a class="card" href="http://northvilletech.co/dasher" rel="sponsored nofollow">
        <span class="card-tag">Get Started</span>
        <h3>Become a DoorDash Driver in 2026</h3>
        <p>Set your own hours, get paid weekly, and earn on your schedule. Sign up through our link and start your first delivery today.</p>
      </a>
      <a class="card" href="/blog/ifly-review">
        <span class="card-tag">Popular Review</span>
        <h3>iFly Indoor Skydiving: The Honest Review</h3>
        <p>What $70 actually gets you. Who it's for. Who it isn't. Written after flying twice and reading every forum thread so you don't have to.</p>
      </a>
    </div>
  </section>

  <section class="container" id="recent">
    <div class="section-heading">
      <h2>Latest posts</h2>
      <a href="/blog">See all →</a>
    </div>
    <ul class="post-list">
      {recent.map(post => (
        <li>
          <a href={`/blog/${post.slug}`}>
            <div class="post-meta">
              <span>{post.data.category}</span>
              <span>•</span>
              <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
            </div>
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <div class="container">
    <Newsletter />
  </div>
</BaseLayout>
