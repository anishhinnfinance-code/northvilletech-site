---
// Replace the action= URL with your Kit / ConvertKit / Mailchimp form endpoint.
// For Kit (formerly ConvertKit): https://app.kit.com/forms → choose your form → Embed → HTML → copy the action URL.
---

<section class="newsletter">
  <h2>Skip the research. Get one recommendation a week.</h2>
  <p>One email, every Monday. One bucket-list experience under $100. Plus occasional reviews and deals you won't get anywhere else.</p>
  <form action="https://app.kit.com/forms/YOUR_FORM_ID/subscriptions" method="post" data-sv-form="YOUR_FORM_ID">
    <input type="email" name="email_address" placeholder="your@email.com" required aria-label="Email address" />
    <button type="submit" class="btn btn-primary">Subscribe →</button>
  </form>
</section>
